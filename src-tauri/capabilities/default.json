{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "sidecar": "pocketbase" },
        { "sidecar": "llama-server" },
        { "sidecar": "whisper-stt" }
      ]
    },
    "process:default",
    "fs:default"
  ]
}
